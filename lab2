#include <iostream>
#include <cstdint>
#include <random>
#include <cmath>
#include <map>
using namespace std;

class Group {
public:
    uint64_t p;
    uint64_t a; //generator

    uint64_t ModExp64(uint64_t b, uint64_t e, uint64_t mod) {
        uint64_t x = 1, y = b % mod;
        while (e > 0) {
            if (e & 1) x = (__uint128_t)x * y % mod;
            y = (__uint128_t)y * y % mod;
            e >>= 1;
        }
        return x;
    }

    bool IsGenerator(uint64_t a) {
        uint64_t phi = p - 1;

        for (uint64_t q = 2; q * q <= phi; q++) {
            if (phi % q == 0) {
                if (ModExp64(a, phi / q, p) == 1) return false;
                while (phi % q == 0) phi /= q;
            }
        }
        if (phi > 1) {
            if (ModExp64(a, (p - 1) / phi, p) == 1) return false;
        }
        return true;
    }

    void Find_Generator(){
        for (uint64_t i = 1; i < p - 1; i++){
            if (IsGenerator(i)){
                a = i;
                break;
            }
        }
    }

    Group(uint64_t p) : p(p) {
        Find_Generator();
    }

    uint64_t Discrete_Log_Brute_Force(uint64_t b){
        uint64_t result = 0;
        for (uint64_t i = 0; i < p - 1; i++){
            if (ModExp64(a, i, p) == b) {
                result = i;
                break;
                }
            }
        return result;
    }

    //SPH
    uint64_t gcdExtended(uint64_t a, uint64_t b, uint64_t &x, uint64_t &y) {
        if (a == 0)  {
            x = 0;
            y = 1;
            return b;
        }

        uint64_t x1, y1;
        uint64_t gcd = gcdExtended(b%a, a, x1, y1);

        x = y1 - (b/a) * x1;
        y = x1;
        return gcd;
    }

    uint64_t GCD(uint64_t a, uint64_t b) {
        uint64_t x = 1, y = 1;
        return gcdExtended(a, b, x, y);
    }

    uint64_t mod_inverse(uint64_t a, uint64_t m) {
        uint64_t x, y;
        gcdExtended(a, m, x, y);
        return (x % m + m) % m;
    }

    uint64_t Polynomial(const uint64_t& x, const uint64_t& n) {
        return (x * x + 1) % n;
    }

    uint64_t Pollard_rho_Floyd(const uint64_t& n) {
        if (n % 2 == 0) return 2;

        uint64_t x = 1;
        uint64_t y = x, d = 1;
        while (d == 1) {
            x = Polynomial(x, n);
            y = Polynomial(Polynomial(y, n), n);
            uint64_t diff = x > y ? x - y : y - x;
            d = GCD(diff, n);
        }
        return (d == n) ? 1 : d;
    }

    bool Miller_Rabin(uint64_t p) {
        int trials = 20;
        if (p % 2 == 0) return false;
        int s = 0;
        uint64_t d = p - 1;

        while (d % 2 == 0) {
            d >>= 1;
            s++;
        }

        mt19937_64 rng(random_device{}());
        uniform_int_distribution<uint64_t> dist(2, p - 3);

        for (int i = 0; i < trials; i++) {
        uint64_t a = dist(rng);
        uint64_t x = ModExp64(a, d, p);
        uint64_t y = 0;
        for (int j = 0; j < s; j++) {
            y = ModExp64(x, 2, p);
            if (y == 1 && x != 1 && x != p - 1) return false;
            x = y;
            }
            if (y != 1) return false;
        }
        return true;
    }

    void Factorize(uint64_t n, map<uint64_t, uint64_t>& factors) {
        if (n == 1) return;

        if (Miller_Rabin(n)) {
            factors[n]++;
            return;
        }

        uint64_t d = Pollard_rho_Floyd(n);
        if (d == 1) {
            factors[n]++;
            return;
        }

        Factorize(d, factors);
        Factorize(n / d, factors);
    }

    uint64_t CRT(const vector<uint64_t>& res, const vector<uint64_t>& mod){
        uint64_t M = 1;
        for (auto m : mod) M *= m;
        uint64_t result = 0;

        for (uint64_t i = 0; i < mod.size(); i++) {
            uint64_t Mi = M / mod[i];
            uint64_t inv = mod_inverse(Mi, mod[i]);
            result = (result + res[i] * Mi % M * inv % M) % M;
        }

        return result;
    }

    uint64_t SolvePrimePower(uint64_t q, uint64_t e, uint64_t b);



    uint64_t Silver_Pohlig_Hellman(uint64_t b){
        uint64_t n = p - 1;

        map<uint64_t, uint64_t> factors;
        Factorize(n, factors);

        vector<uint64_t> res;
        vector<uint64_t> mod;

        for (auto [q, e] : factors) {
            uint64_t qe = pow(q, e);

            uint64_t xi = SolvePrimePower(q, e, b);
            res.push_back(xi);
            mod.push_back(qe);
        }

        return CRT(res, mod);
    }

};

int main(){
    Group G(73);

    uint64_t Log = G.Discrete_Log_Brute_Force(20);
    cout << "Generator: " << G.a << "\n";
    cout << "Discrete log: " << Log << "\n";


    return 0;
}








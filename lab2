#include <iostream>
#include <gmpxx.h>
#include <map>
#include <vector>
#include <chrono>
using namespace std;
using namespace chrono;

class Group {
public:
    mpz_class p;
    mpz_class a;

    gmp_randclass rng = gmp_randclass(gmp_randinit_mt);

    Group(mpz_class p) : p(p) {
        rng.seed(time(nullptr));
    }

    mpz_class ModExp64(mpz_class b, mpz_class e, mpz_class mod) {
        mpz_class x = 1;
        b %= mod;

        while (e > 0) {
            if (mpz_odd_p(e.get_mpz_t()))
                x = (x * b) % mod;

            b = (b * b) % mod;
            e >>= 1;
        }
        return x;
    }

    mpz_class Discrete_Log_Brute_Force(mpz_class b) {
        mpz_class cur = 1;

        for (mpz_class i = 0; i < p - 1; i++) {
            if (cur == b) return i;
            cur = (cur * a) % p;
        }

        return -1;
    }

    mpz_class mod_inverse(mpz_class a, mpz_class m) {
        mpz_class x, y, gcd;

        mpz_gcdext(gcd.get_mpz_t(),
                   x.get_mpz_t(),
                   y.get_mpz_t(),
                   a.get_mpz_t(),
                   m.get_mpz_t());

        x %= m;
        if (x < 0) x += m;
        return x;
    }

    mpz_class Polynomial(mpz_class x, mpz_class c, mpz_class n) {
        return (x * x + c) % n;
    }

    mpz_class Pollard_rho_Floyd(mpz_class n, mpz_class c) {
        if (n % 2 == 0) return 2;

        mpz_class x = rng.get_z_range(n);
        mpz_class y = x;
        mpz_class d = 1;

        while (d == 1) {
            x = Polynomial(x, c, n);
            y = Polynomial(Polynomial(y, c, n), c, n);

            mpz_class diff = (x > y ? x - y : y - x);
            d = gcd(diff, n);
        }

        if (d == n) return 1;
        return d;
    }

    void Factorize(mpz_class n, map<mpz_class, mpz_class>& factors) {
        if (n == 1) return;

        if (mpz_probab_prime_p(n.get_mpz_t(), 20)) {
            factors[n]++;
            return;
        }

        mpz_class d = 1;

        while (d == 1 || d == n) {
            mpz_class c = rng.get_z_range(n);
            d = Pollard_rho_Floyd(n, c);
        }

        Factorize(d, factors);
        Factorize(n / d, factors);
    }

    mpz_class SolvePrimePower(mpz_class q, mpz_class e, mpz_class b) {
        mpz_class n = p - 1;
        mpz_class x = 0;
        mpz_class q_k = 1;

        mpz_class g_k = ModExp64(a, n / q, p);                      // a ^ (n / q) mod p

        for (mpz_class k = 0; k < e; k++) {

            mpz_class exp = n / (q_k * q);                          // n / q_i^(k+1)
            mpz_class a_inv_x = ModExp64(a, (n - x % n) % n, p);    // a^-1 mod p
            mpz_class inner = (b * a_inv_x) % p;                    //(b * a ^ -1) mod p

            mpz_class h_k = ModExp64(inner, exp, p);                // (b * a ^ -1) ^ (n/p^k) mod p

            mpz_class cur = 1;                                      // counter
            mpz_class x_k = 0;                                      // residue output

            for (mpz_class j = 0; j < q; j++) {                     // "table"
                if (cur == h_k) {
                    x_k = j;
                    break;
                }
                cur = (cur * g_k) % p;                              // collision
            }

            x += x_k * q_k;                                         // x = x0 + x1 * q_i + x2 * q_i^2 ...
            q_k *= q;                                               // q_i := q_i * q
        }

        return x % q_k;
    }

    mpz_class CRT(vector<mpz_class> res, vector<mpz_class> mod) {

        mpz_class M = 1;
        for (auto &x : mod) M *= x;

        mpz_class result = 0;

        for (size_t i = 0; i < mod.size(); i++) {
            mpz_class Mi = M / mod[i];
            mpz_class inv = mod_inverse(Mi % mod[i], mod[i]);
            result += (res[i] * Mi % M) * inv;
        }

        return result % M;
    }

     mpz_class Silver_Pohlig_Hellman(mpz_class b) {
        mpz_class n = p - 1;

        map<mpz_class, mpz_class> factors;
        Factorize(n, factors);

        vector<mpz_class> res;
        vector<mpz_class> mod;

        for (auto &[q, e] : factors) {
            mpz_class xi = SolvePrimePower(q, e, b);
            res.push_back(xi);

            mpz_class qe = 1;
            for (mpz_class i = 0; i < e; i++)
                qe *= q;
            mod.push_back(qe);
        }

        return CRT(res, mod);
    }
};

int main() {
    mpz_class p, b;
    cout << "Enter group mod: ";
    cin >> p;
    Group G(p);

    cout << "Generator: ";
    cin >> G.a;
    cout << "Enter b: ";
    cin >> b;

    auto start2 = high_resolution_clock::now();
    mpz_class log_sph = G.Silver_Pohlig_Hellman(b);
    auto end2 = high_resolution_clock::now();
    auto duration2 = duration_cast<microseconds>(end2 - start2);
    cout << "Silver-Pohlig-Hellman: " << G.a << "^" << log_sph << " = " << b << " (mod " << G.p << ")\n";
    cout << "SPH verify: " << G.ModExp64(G.a, log_sph, p) << "\n";
    cout << "SPH time: " << duration2.count() << " microseconds\n";

    auto start1 = high_resolution_clock::now();
    mpz_class log_bf  = G.Discrete_Log_Brute_Force(b);
    auto end1 = high_resolution_clock::now();
    auto duration1 = duration_cast<microseconds>(end1 - start1);
    cout << "Brute force:  " << G.a << "^" << log_bf  << " = " << b << " (mod " << G.p << ")\n";
    cout << "BF  verify: " << G.ModExp64(G.a, log_bf,  p) << "\n";
    cout << "Brute force time: " << duration1.count() << " microseconds\n\n";

    return 0;
}




































































#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <chrono>

using namespace std;
using namespace chrono;

static const int RANK = 30;

class LLL{

private:
    int basis[RANK][RANK];
    double b_star[RANK][RANK];
    double mu[RANK][RANK];

    double B[RANK];
    double delta;

public:
    double Scalar_Product(const double* a, const double* b) {
        double s = 0.0;
        for (int i = 0; i < RANK; i++) s += a[i] * b[i];
        return s;
    }

    double Scalar_Product_Int_Double(const int* a, const double* b) {
        double s = 0.0;
        for (int i = 0; i < RANK; i++) s += a[i] * b[i];
        return s;
    }

    void SwapRows(int a, int b) {
        for (int i = 0; i < RANK; i++) swap(basis[a][i], basis[b][i]);
    }

    void Generate_Matrix(){
        const int LIMIT = 50000;
        static mt19937_64 rng(random_device{}());
        uniform_int_distribution<int32_t> dist(-LIMIT, LIMIT);
        for (int i = 0; i < RANK; i++){
            for (int j = 0; j < RANK; j++){
                basis[i][j] = dist(rng);
            }
        }
    }

    LLL(float d){
        if (d <= 0.25 || d >= 1) {cerr << "Invalid parameter.\n"; exit(1);}
        delta = d;
        Generate_Matrix();
    }

     void Gram_Schmidt() {
        for (int i = 0; i < RANK; i++) {
            for (int t = 0; t < RANK; t++) b_star[i][t] = basis[i][t];

            for (int j = 0; j < i; j++) {
                mu[i][j] = Scalar_Product_Int_Double(basis[i], b_star[j]) / B[j];
                for (int t = 0; t < RANK; t++) b_star[i][t] -= mu[i][j] * b_star[j][t];
            }

            B[i] = Scalar_Product(b_star[i], b_star[i]);
        }
    }

    void SizeReduce(int k) {
        for (int j = k - 1; j >= 0; j--) {
            int r = (int)round(mu[k][j]);
            if (r != 0) {
                for (int i = 0; i < RANK; i++) basis[k][i] -= r * basis[j][i];
            }
        }
    }

    int LLL_Alg() {
        int swap_count = 0;
        Gram_Schmidt();
        int k = 1;

        while (k < RANK) {
            SizeReduce(k);
            Gram_Schmidt();
            double lhs = B[k];
            double rhs = (delta - mu[k][k - 1] * mu[k][k - 1]) * B[k - 1];
            if (lhs >= rhs) {
                k++;

            } else {
                SwapRows(k, k - 1); swap_count++;
                Gram_Schmidt();
                k = max(k - 1, 1);
            }
        }

        return swap_count;
    }


};


using namespace std;

int main()
{

    vector<double> deltas = {
        0.50,
        0.75,
        0.90,
        0.95,
        0.99
    };

    auto time = nanoseconds::zero();
    int Swaps = 0;

    for (auto d : deltas){
        cout << "Delta = " << d << "\n";
        for (int i = 0; i < 50; i++){
            LLL M(d);
            auto Start = high_resolution_clock::now();
            M.LLL_Alg();
            auto End = high_resolution_clock::now();
            auto duration = duration_cast<nanoseconds>(End - Start);
            time = time + duration;
        }
        cout << "Avg  time = " << time.count()/50 << " nanoseconds \n";
        cout << "Avg swaps = " << Swaps/50 << "\n";
        cout << "________________________\n\n";
    }


    return 0;
}



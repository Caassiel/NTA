#include <iostream>
#include <vector>
#include <random>
#include <cmath>
#include <chrono>

using namespace std;
using namespace chrono;

static const int RANK   = 30;
static const int TRIALS = 50;
static const int LIMIT  = 10000;

class LLL{

private:
    int64_t basis[RANK][RANK]   = {};
    double b_star[RANK][RANK]   = {};
    double mu[RANK][RANK]       = {};

    double B[RANK]              = {};
    double delta                = 0.0;

public:
    inline double Scalar_Product(const double* a, const double* b) {
        double s = 0.0;
        for (int i = 0; i < RANK; i++) s += a[i] * b[i];
        return s;
    }

    inline double Scalar_Product_Int_Double(const int64_t* a, const double* b) {
        double s = 0.0;
        for (int i = 0; i < RANK; i++) s += a[i] * b[i];
        return s;
    }

    void SwapRows(int a, int b) {
        for (int i = 0; i < RANK; i++) swap(basis[a][i], basis[b][i]);
    }

    void Generate_Matrix(){
        static mt19937_64 rng(random_device{}());
        uniform_int_distribution<int32_t> dist(-LIMIT, LIMIT);
        for (int i = 0; i < RANK; i++){
            for (int j = 0; j < RANK; j++){
                basis[i][j] = dist(rng);
            }
        }
    }

    LLL(double d){
        if (d <= 0.25 || d >= 1) {cerr << "Invalid parameter.\n"; exit(1);}
        delta = d;
        Generate_Matrix();
    }

    void FULL_Gram_Schmidt() {
        for (int i = 0; i < RANK; i++) {
            for (int t = 0; t < RANK; t++) b_star[i][t] = basis[i][t];
            for (int j = 0; j < i; j++) {
                mu[i][j] = Scalar_Product_Int_Double(basis[i], b_star[j]) / B[j];
                for (int t = 0; t < RANK; t++) b_star[i][t] -= mu[i][j] * b_star[j][t];
            }

            B[i] = Scalar_Product(b_star[i], b_star[i]);
        }
    }

    void REDUCED_Gram_Schmidt(int k) {
        double mu_k         = mu[k][k - 1];
        double B_k          = B[k];
        double B_km1        = B[k - 1];

        double B_new_km1    = B_k + mu_k * mu_k * B_km1;
        double mu_new       = mu_k * B_km1 / B_new_km1;
        double B_new_k      = B_km1 * B_k / B_new_km1;

        for (int t = 0; t < RANK; t++) {
            double old_km1    = b_star[k - 1][t];
            b_star[k - 1][t] = b_star[k][t] + mu_k * old_km1;
            b_star[k][t]     = mu_new * b_star[k][t] + (B_new_k / B_k) * old_km1;
        }

        B[k - 1] = B_new_km1;
        B[k]     = B_new_k;

        for (int i = k + 1; i < RANK; i++) {
            double t     = mu[i][k];
            mu[i][k]     = mu[i][k - 1] - mu_k * t;
            mu[i][k - 1] = t + mu_new * mu[i][k];
        }

        mu[k][k - 1] = mu_new;

        for (int j = 0; j < k - 1; j++) {
            double old_mu_km1 = mu[k - 1][j];
            mu[k - 1][j] = mu[k][j];
            mu[k][j]     = old_mu_km1;
        }
    }

    void SizeReduce(int k) {
        for (int j = k - 1; j >= 0; j--) {
            int r = (int)round(mu[k][j]);
            if (r != 0) {
                for (int i = 0; i < RANK; i++) basis[k][i] -= r * basis[j][i];
                for (int l = 0; l < j; l++) mu[k][l] -= r * mu[j][l];
                mu[k][j] -= r;
            }
        }
    }

    void Recompute_Row_k(int k) {
        for (int t = 0; t < RANK; t++) b_star[k][t] = (double)basis[k][t];
        for (int j = 0; j < k; j++) {
            mu[k][j] = Scalar_Product_Int_Double(basis[k], b_star[j]) / B[j];
            for (int t = 0; t < RANK; t++) b_star[k][t] -= mu[k][j] * b_star[j][t];
        }
        B[k] = Scalar_Product(b_star[k], b_star[k]);
    }

    int LLL_Alg() {
        int swap_count = 0;
        FULL_Gram_Schmidt();
        int k = 1;

        while (k < RANK) {
            SizeReduce(k);
            Recompute_Row_k(k);
            double lhs = B[k];
            double rhs = (delta - mu[k][k - 1] * mu[k][k - 1]) * B[k - 1];
            if (lhs >= rhs) {
                k++;

            } else {
                SwapRows(k, k - 1); swap_count++;
                REDUCED_Gram_Schmidt(k);
                k = max(k - 1, 1);
            }
        }

        return swap_count;
    }

    double b_i_norm(int i){
        double norm_sq = 0.0;
        for (int j = 0; j < RANK; j++) norm_sq += 1.0 * basis[i][j] * basis[i][j];
        return sqrt(norm_sq);
    }

    double Hadamard_Coefficient_GS() {
        double log_det = 0.0;
        double log_norm_product = 0.0;

        for (int i = 0; i < RANK; i++) log_det += 0.5 * log(B[i]);
        for (int i = 0; i < RANK; i++) log_norm_product += log(b_i_norm(i));

        return exp((log_det - log_norm_product) / RANK);
    }



};

int main(){
    vector<double> deltas = {
        0.26,
        0.50,
        0.75,
        0.90,
        0.95,
        0.99
    };

    cout << "CURRENT RANK = " << RANK << "\n\n";

    for (auto d : deltas){
        auto    time = microseconds::zero();
        int     Swaps = 0;
        double  HC = 0.0;
        double  b1_len = 0.0;
        cout << "Delta = " << d << "\n";

        for (int i = 0; i < TRIALS; i++){
            LLL M(d);
            auto Start = high_resolution_clock::now();
            Swaps  += M.LLL_Alg();
            auto End = high_resolution_clock::now();
            auto duration = duration_cast<microseconds>(End - Start);
            time   += duration;
            HC     += M.Hadamard_Coefficient_GS();
            b1_len += M.b_i_norm(0);
        }

        cout << "Avg  time   = " << time.count()/TRIALS << " microseconds \n";
        cout << "Avg swaps   = " << (double)Swaps/TRIALS << "\n";
        cout << "Avg H(B)    = " << HC/TRIALS << "\n";
        cout << "Avg ||b1||  = " << b1_len/TRIALS << "\n";
        cout << "________________________\n\n";
    }


    return 0;
}





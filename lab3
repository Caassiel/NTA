IndexCalculus::IndexCalculus(const mpz_class& p, const mpz_class& g): p(p), g(g) {}

void IndexCalculus::buildFactorBase(int B) {
    for (int i = 2; i <= B; i++) {
        bool prime = true;
        for (int j = 2; j*j <= i; j++) {
            if (i % j == 0) {
                prime = false;
                break;
            }
        }
        if (prime) factor_base.push_back(i);
    }
}

bool IndexCalculus::isSmooth(mpz_class n, vector<int>& exponents) {
    exponents.assign(factor_base.size(), 0);

    for (size_t i = 0; i < factor_base.size(); i++) {
        const mpz_class& prime = factor_base[i];
        while (n % prime == 0) {
            n /= prime;
            exponents[i]++;
        }
    }
    return (n == 1);
}

void IndexCalculus::collectRelations(int required) {
    mpz_class k = 1;

    while ((int)relations.size() < required) {
        mpz_class val;
        mpz_powm(val.get_mpz_t(), g.get_mpz_t(), k.get_mpz_t(), p.get_mpz_t());

        vector<int> exponents;
        if (isSmooth(val, exponents)) {
            relations[k] = exponents;
        }
        k++;
    }
}

vector<mpz_class> IndexCalculus::solveLinearSystem() {

    // Implement modular Gaussian elimination

    vector<mpz_class> logs(factor_base.size());
    return logs;
}

mpz_class IndexCalculus::solve(const mpz_class& h) {
    buildFactorBase(50);
    collectRelations(factor_base.size()+5);

    auto logs = solveLinearSystem();

    mpz_class k = 1;
    while (true) {
        mpz_class val, temp;
        mpz_powm(temp.get_mpz_t(), g.get_mpz_t(), k.get_mpz_t(), p.get_mpz_t());
        val = (h * temp) % p;

        vector<int> exponents;
        if (isSmooth(val, exponents)) {
            mpz_class result = 0;

            for (size_t i = 0; i < exponents.size(); i++) {
                result += exponents[i] * logs[i];
            }

            result -= k;
            result %= (p - 1);

            if (result < 0) result += (p - 1);
            return result;
        }
        k++;
    }
}


int main() {
    mpz_class p = 1019;
    mpz_class g = 2;
    mpz_class h = 5;

    IndexCalculus ic(p, g);

    cout << "g = " << g << "\n";
    cout << "h = " << h << "\n";
    cout << "p = " << p << "\n\n";

    mpz_class x = ic.solve(h);

    cout << "Result x = " << x << "\n";

    mpz_class check;
    mpz_powm(check.get_mpz_t(), g.get_mpz_t(), x.get_mpz_t(), p.get_mpz_t());

    cout << "Verification: g^x mod p = " << check << "\n";

    if (check == h)
        cout << "Correct\n";
    else
        cout << "Incorrect\n";

    return 0;
}


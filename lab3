class IndexCalculus {
public:
    IndexCalculus(const mpz_class& p, const mpz_class& a);
    mpz_class solve(const mpz_class& b);

    mpz_class p, a;

    std::vector<mpz_class> factor_base;
    std::map<mpz_class, std::vector<int>> relations;

    void buildFactorBase(int B);
    bool isSmooth(mpz_class n, std::vector<int>& e);
    void collectRelations(int r);
    std::vector<mpz_class> solveLinearSystem();
};

IndexCalculus::IndexCalculus(const mpz_class& p, const mpz_class& a): p(p), a(a) {}

void IndexCalculus::buildFactorBase(int B) {
    for (int i = 2; i <= B; i++) {
        mpz_class k(i);
        if (Miller_Rabin(k)) factor_base.push_back(i);
    }
}

bool IndexCalculus::isSmooth(mpz_class n, vector<int>& exponents) {
    return FactorOverBase(n, factor_base, exponents);
}

void IndexCalculus::collectRelations(int required) {
    mpz_class k = 1;

    while ((int)relations.size() < required) {
        mpz_class val;
        mpz_powm(val.get_mpz_t(), a.get_mpz_t(), k.get_mpz_t(), p.get_mpz_t());

        vector<int> exponents;
        if (isSmooth(val, exponents)) {
            relations[k] = exponents;
        }
        k++;
    }
}

mpz_class mod_inverse(mpz_class a, mpz_class m) {
    mpz_class x, y, gcd;
    mpz_gcdext(gcd.get_mpz_t(), x.get_mpz_t(), y.get_mpz_t(), a.get_mpz_t(), m.get_mpz_t());

    x %= m;
    if (x < 0) x += m;
    return x;
}


mpz_class CRT(vector<mpz_class> res, vector<mpz_class> mod) {
    mpz_class M = 1;
    for (auto &x : mod) M *= x;
    mpz_class result = 0;
    for (size_t i = 0; i < mod.size(); i++) {
        mpz_class Mi = M / mod[i];
        mpz_class inv = mod_inverse(Mi % mod[i], mod[i]);
        result += (res[i] * Mi % M) * inv;
    }
    return result % M;
}

static vector<mpz_class> solveModQ(vector<vector<mpz_class>> A, vector<mpz_class> b,int n, int m, const mpz_class& q){
    vector<int> pivot_col(m, -1);

    for (int col = 0, r = 0; col < n && r < m; col++) {
        int pivot = -1;
        for (int i = r; i < m; i++) {
            mpz_class g;
            mpz_gcd(g.get_mpz_t(), A[i][col].get_mpz_t(), q.get_mpz_t());
            if (g == 1) { pivot = i; break; }
        }
        if (pivot == -1) continue;

        swap(A[r], A[pivot]);
        swap(b[r], b[pivot]);
        pivot_col[r] = col;

        mpz_class inv;
        mpz_invert(inv.get_mpz_t(), A[r][col].get_mpz_t(), q.get_mpz_t());

        for (int j = col; j < n; j++)
            A[r][j] = (A[r][j] * inv) % q;
        b[r] = (b[r] * inv) % q;

        for (int i = 0; i < m; i++) {
            if (i != r && A[i][col] != 0) {
                mpz_class fac = A[i][col];
                for (int j = col; j < n; j++) {
                    A[i][j] = ((A[i][j] - fac * A[r][j]) % q + q) % q;
                }
                b[i] = ((b[i] - fac * b[r]) % q + q) % q;
            }
        }
        r++;
    }

    vector<mpz_class> logs(n, 0);
    for (int i = 0; i < m; i++)
        if (pivot_col[i] != -1)
            logs[pivot_col[i]] = b[i];

    return logs;
}

vector<mpz_class> IndexCalculus::solveLinearSystem() {
    mpz_class mod = p - 1;
    int n = factor_base.size();
    int m = relations.size();

    vector<vector<mpz_class>> A(m, vector<mpz_class>(n));
    vector<mpz_class> b(m);
    int row = 0;
    for (auto& [k, exps] : relations) {
        b[row] = k % mod;
        for (int j = 0; j < n; j++)
            A[row][j] = exps[j] % mod;
        row++;
    }

    auto factored = factorize(p - 1);

    vector<mpz_class>              sub_mods;
    vector<vector<mpz_class>>      sub_logs;

    for (auto& [prime, exp] : factored) {
        mpz_class q;
        mpz_pow_ui(q.get_mpz_t(), prime.get_mpz_t(), (unsigned)exp);
        sub_mods.push_back(q);

        vector<vector<mpz_class>> Aq(m, vector<mpz_class>(n));
        vector<mpz_class>          bq(m);
        for (int i = 0; i < m; i++) {
            bq[i] = b[i] % q;
            for (int j = 0; j < n; j++)
                Aq[i][j] = A[i][j] % q;
        }

        sub_logs.push_back(solveModQ(Aq, bq, n, m, q));
    }

    vector<mpz_class> logs(n);
    for (int i = 0; i < n; i++) {
        vector<mpz_class> residues;
        for (auto& sl : sub_logs)
            residues.push_back(sl[i]);
        logs[i] = CRT(residues, sub_mods);
    }

    return logs;
}

int ComputeFactorBaseBound(const mpz_class& n) {
    double ln_n = mpz_sizeinbase(n.get_mpz_t(), 2) * log(2.0);
    double ln_ln_n = log(ln_n);
    double B = 3.38 * exp(0.5 * sqrt(ln_n * ln_ln_n));
    if (B < 50) B = 50;
    if (B > 50000) B = 50000;

    return (int)B;
}

mpz_class IndexCalculus::solve(const mpz_class& b) {
    buildFactorBase(ComputeFactorBaseBound(p));
    collectRelations(factor_base.size()+10);

    auto logs = solveLinearSystem();

    mpz_class k = 1;
    while (true) {
        mpz_class val, temp;
        mpz_powm(temp.get_mpz_t(), a.get_mpz_t(), k.get_mpz_t(), p.get_mpz_t());
        val = (b * temp) % p;

        vector<int> exponents;
        if (isSmooth(val, exponents)) {
            mpz_class result = 0;

            for (size_t i = 0; i < exponents.size(); i++) {
                result += exponents[i] * logs[i];
            }

            result -= k;
            result %= (p - 1);

            if (result < 0) result += (p - 1);
            return result;
        }
        k++;
    }
}


